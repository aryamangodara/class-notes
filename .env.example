# Auth — identical contract to the Grader, so the same key works here.
# Pick ONE method.

# AI Studio (simplest):
GEMINI_API_KEY=

# OR Vertex AI:
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=global

# OPTIONAL — Langfuse cost/observability tracking. If both keys are set, every Gemini
# call is logged as a generation with token usage; Langfuse computes cost (it already
# prices gemini-3.1-pro-preview / gemini-3.5-flash). Leave blank to disable (default).
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com   # or your self-hosted URL
